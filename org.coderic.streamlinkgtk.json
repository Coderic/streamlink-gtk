{
    "id" : "org.coderic.streamlinkgtk",
    "runtime" : "org.gnome.Platform",
    "runtime-version" : "50",
    "sdk" : "org.gnome.Sdk",
    "command" : "streamlink-gtk",
    "finish-args" : [
        "--share=network",
        "--share=ipc",
        "--socket=fallback-x11",
        "--device=dri",
        "--socket=wayland",
        "--socket=session-bus",
        "--talk-name=org.freedesktop.Flatpak"
    ],
    "cleanup" : [
        "/include",
        "/lib/pkgconfig",
        "/man",
        "/share/doc",
        "/share/gtk-doc",
        "/share/man",
        "/share/pkgconfig",
        "*.la",
        "*.a"
    ],
    "modules" : [
        {
            "name" : "ffmpeg",
            "buildsystem" : "autotools",
            "config-opts" : [
                "--disable-static",
                "--enable-shared",
                "--disable-doc",
                "--disable-ffplay",
                "--disable-avdevice",
                "--enable-pic"
            ],
            "sources" : [
                {
                    "type" : "archive",
                    "url" : "https://ffmpeg.org/releases/ffmpeg-7.1.tar.xz",
                    "sha256" : "40973d44970dbc83ef302b0609f2e74982be2d85916dd2ee7472d30678a7abe6"
                }
            ],
            "cleanup" : [
                "/include",
                "/share/ffmpeg",
                "/share/doc",
                "*.a"
            ]
        },
        {
            "name" : "python3-streamlink-wheels",
            "buildsystem" : "simple",
            "build-commands" : [
                "pip3 install --verbose --exists-action=i --no-index --find-links=\"file://${PWD}\" --prefix=${FLATPAK_DEST} --no-cache-dir --no-build-isolation -r requirements.txt"
            ],
            "sources" : [
                {
                    "type" : "file",
                    "path" : "requirements.txt"
                },
                {
                    "type" : "dir",
                    "path" : "flatpak/pypi-wheels"
                }
            ]
        },
        {
            "name" : "streamlink-gtk",
            "builddir" : true,
            "buildsystem" : "meson",
            "sources" : [
                {
                    "type" : "dir",
                    "path" : "."
                }
            ],
            "config-opts" : [
                "--libdir=lib"
            ]
        }
    ],
    "build-options" : {
        "env" : {        }
    }
}
