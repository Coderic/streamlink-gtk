<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>org.coderic.streamlinkgtk</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>Apache-2.0</project_license>

  <name>StreamlinkGTK</name>
  <summary>GTK front-end for Streamlink queues</summary>
  <description>
    <p>
      GTK 4 queue for Streamlink: resolve qualities, record to disk (mux with FFmpeg via Streamlink’s
      --ffmpeg-fout), or play in an external player. Install the distribution ffmpeg package for native
      runs; the Flatpak build ships FFmpeg as a bundled module.
    </p>
  </description>

  <developer id="org.coderic">
    <name>Coderic</name>
  </developer>

  <url type="homepage">https://github.com/Coderic/streamlink-gtk</url>
  <url type="vcs-browser">https://github.com/Coderic/streamlink-gtk</url>
  <url type="bugtracker">https://github.com/Coderic/streamlink-gtk/issues</url>

  <translation type="gettext">streamlink-gtk</translation>
  <launchable type="desktop-id">org.coderic.streamlinkgtk.desktop</launchable>
  <content_rating type="oars-1.1" />

  <branding>
    <color type="primary" scheme_preference="light">#3584e4</color>
    <color type="primary" scheme_preference="dark">#3584e4</color>
  </branding>

  <screenshots>
    <screenshot type="default">
      <image>https://raw.githubusercontent.com/Coderic/streamlink-gtk/main/data/icons/hicolor/scalable/apps/org.coderic.streamlinkgtk.svg</image>
      <caption>StreamlinkGTK icon</caption>
    </screenshot>
  </screenshots>

  <releases>
    <release version="0.0.1" date="2026-04-16">
      <url type="details">https://github.com/Coderic/streamlink-gtk/releases/tag/0.0.1</url>
      <description translate="no">
        <p>Initial published build: Flatpak bundle and Windows zip from CI.</p>
      </description>
    </release>
  </releases>

</component>
